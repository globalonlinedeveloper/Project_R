{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ratel.dev/schema/tables/grammar_point.json",
  "title": "GrammarPoint (R-C4) — neutral phenomenon; explanation lives in the gloss layer; N/A = zero rows",
  "type": "object",
  "required": ["grammar_id", "locale", "name", "cefr_level", "provenance"],
  "properties": {
    "grammar_id": { "$ref": "https://ratel.dev/schema/common.json#/$defs/content_id" },
    "locale": { "$ref": "https://ratel.dev/schema/common.json#/$defs/bcp47" },
    "name": { "type": "string", "minLength": 1 },
    "rule_text_ref": { "$ref": "https://ratel.dev/schema/common.json#/$defs/content_id" },
    "cefr_level": { "$ref": "https://ratel.dev/schema/enums.json#/$defs/cefr_level" },
    "concept_refs": { "type": "array", "items": { "$ref": "https://ratel.dev/schema/common.json#/$defs/content_id" } },
    "example_refs": { "type": "array", "items": { "$ref": "https://ratel.dev/schema/common.json#/$defs/content_id" } },
    "feature_tags": { "$ref": "https://ratel.dev/schema/common.json#/$defs/features" },
    "provenance": { "$ref": "https://ratel.dev/schema/common.json#/$defs/provenance" }
  },
  "additionalProperties": false
}
