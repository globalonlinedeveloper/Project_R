{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ratel.dev/schema/tables/user_phoneme_state.json",
  "title": "UserPhonemeState (R-J) — per-phoneme pronunciation mastery for the learner.",
  "type": "object",
  "required": [
    "user_phoneme_state_id",
    "user_id",
    "phoneme_id",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "user_phoneme_state_id": {
      "$ref": "https://ratel.dev/schema/common.json#/$defs/uuid"
    },
    "user_id": {
      "$ref": "https://ratel.dev/schema/common.json#/$defs/user_id"
    },
    "phoneme_id": {
      "$ref": "https://ratel.dev/schema/common.json#/$defs/content_id"
    },
    "locale": {
      "$ref": "https://ratel.dev/schema/common.json#/$defs/bcp47"
    },
    "mastery": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "attempts": {
      "type": "integer",
      "minimum": 0
    },
    "last_score": {
      "type": "number"
    },
    "due": {
      "oneOf": [
        {
          "type": "string",
          "format": "date-time"
        },
        {
          "type": "null"
        }
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
