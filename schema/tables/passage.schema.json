{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ratel.dev/schema/tables/passage.json",
  "title": "Passage — long-form comprehension content (Graded Stories · Read&Listen · Podcasts · Watch); text is sentence_refs into the shared sentence table, titles/explanations live in the gloss layer",
  "type": "object",
  "required": ["passage_id", "locale", "kind", "title_ref", "cefr_level", "sentence_refs", "provenance"],
  "properties": {
    "passage_id": { "$ref": "https://ratel.dev/schema/common.json#/$defs/content_id" },
    "locale": { "$ref": "https://ratel.dev/schema/common.json#/$defs/bcp47" },
    "kind": { "$ref": "https://ratel.dev/schema/enums.json#/$defs/passage_kind" },
    "title_ref": { "$ref": "https://ratel.dev/schema/common.json#/$defs/content_id" },
    "cefr_level": { "$ref": "https://ratel.dev/schema/enums.json#/$defs/cefr_level" },
    "theme": { "type": "string" },
    "collection_id": { "$ref": "https://ratel.dev/schema/common.json#/$defs/content_id" },
    "sentence_refs": { "type": "array", "minItems": 1, "items": { "$ref": "https://ratel.dev/schema/common.json#/$defs/content_id" } },
    "audio_ref": { "$ref": "https://ratel.dev/schema/common.json#/$defs/content_id" },
    "video_ref": { "$ref": "https://ratel.dev/schema/common.json#/$defs/content_id" },
    "video_prompt": { "type": "string" },
    "duration_ms": { "type": "integer", "minimum": 0 },
    "explain_ref": { "$ref": "https://ratel.dev/schema/common.json#/$defs/content_id" },
    "provenance": { "$ref": "https://ratel.dev/schema/common.json#/$defs/provenance" }
  },
  "additionalProperties": false
}
